def get_scores_dict(algo, train_user_watched, val_user_movie, all_movies):
    """
    Returns dict: {user_id: {movie_id: predicted_score}}
    Useful for ensemble weight combining.
    """
    scores = {}
    for uid in val_user_movie.keys():
        seen = train_user_watched.get(uid, set())
        candidates = [m for m in all_movies if m not in seen]
        scores[uid] = {mid: algo.predict(uid, mid).est for mid in candidates}
    return scores

