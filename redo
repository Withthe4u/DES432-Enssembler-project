scores_item_cf = get_scores_dict(item_cf, train_user_watched, val_user_movie, all_movies)
print('Done! scores_svd, scores_user_cf, scores_item_cf are ready for ensemble step.')

def ensemble_top_n(scores_svd, scores_user_cf, scores_item_cf, val_user_movie, w1, w2, w3, n=10):
    """
    Combine 3 model scores using weighted sum for each user.
    w1 = weight for SVD, w2 = weight for User-Based CF, w3 = weight for Item-Based CF
    Returns dict: {user_id: [top 10 movie_ids]}
    """
    top_n = {}
    for uid in val_user_movie.keys():
        all_candidates = set(scores_svd[uid].keys()) | set(scores_user_cf[uid].keys()) | set(scores_item_cf[uid].keys())

        combined = {}
        for mid in all_candidates:
            s1 = scores_svd[uid].get(mid, 0)
            s2 = scores_user_cf[uid].get(mid, 0)
            s3 = scores_item_cf[uid].get(mid, 0)
            combined[mid] = w1 * s1 + w2 * s2 + w3 * s3

        sorted_movies = sorted(combined.items(), key=lambda x: x[1], reverse=True)
        top_n[uid] = [mid for mid, _ in sorted_movies[:n]]

    return top_n




# # ============================================================
# # GRID SEARCH FOR BEST WEIGHTS
# # ============================================================
# # We search over weights that sum to 1.0
# # Step size of 0.1 gives a manageable search space

print("Running grid search for best ensemble weights...")
print("(This may take a few minutes)\n")

best_score = -1
best_weights = (1/3, 1/3, 1/3)  # default equal weights
results = []

step = 0.1
weight_options = np.arange(0, 1 + step, step)

for w1 in weight_options:
    for w2 in weight_options:
        w3 = round(1.0 - w1 - w2, 10)
        if w3 < 0 or w3 > 1:
            continue  # skip invalid combinations

        top_n = ensemble_top_n(scores_svd, scores_user_cf, scores_item_cf, val_user_movie, w1, w2, w3)
        score = precision_at_10(top_n, val_user_movie)
        results.append((round(w1, 2), round(w2, 2), round(w3, 2), score))

        if score > best_score:
            best_score = score
            best_weights = (round(w1, 2), round(w2, 2), round(w3, 2))

print(f"Best weights  -> SVD: {best_weights[0]}, KNN: {best_weights[1]}, NMF: {best_weights[2]}")
print(f"Best Precision@10: {best_score:.4f}")

